# UniSpam AI v2.0 Environment Configuration

# Gemini AI API Key (Get from Google AI Studio: https://aistudio.google.com/app/apikeys)
GEMINI_API_KEY=your_gemini_api_key_here

# Google Safe Browsing API Key (Optional - get from Google Cloud Console)
# Without this, URL safety checks will be skipped but app will still work
GOOGLE_SAFE_BROWSING_API_KEY=your_safe_browsing_key_here

# FastAPI Settings
DEBUG=true
RELOAD=true

# Port
PORT=8000
